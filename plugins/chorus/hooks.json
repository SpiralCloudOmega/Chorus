{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/on-session-start.sh",
            "timeout": 20,
            "statusMessage": "Chorus: checkin"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*chorus_pm_submit_proposal",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/on-post-submit-proposal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*chorus_submit_for_verify",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/on-post-submit-for-verify.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*chorus_admin_verify_task",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/on-post-verify-task.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
